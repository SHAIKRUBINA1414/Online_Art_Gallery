{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Flask Art Gallery",
      "type": "python",
      "request": "launch",
      "module": "flask",
      "env": {
        "FLASK_APP": "app.py",
        "FLASK_DEBUG": "1"
      },
      "args": [
        "run",
        "--debug",
        "--host",
        "127.0.0.1",
        "--port",
        "5000"
      ],
      "jinja": true,
      "justMyCode": true
    }
  ]
}

  <aside class="chatbot" id="chatbot" aria-label="Riri chatbot assistant">
    <button class="chatbot-toggle" type="button" aria-label="Open Riri chatbot" aria-expanded="false">
      <img src="/static/img/riri.png" alt="Riri avatar" width="64" height="64">
    </button>
    <div class="chatbot-panel" role="dialog" aria-label="Chat with Riri">
      <div class="chatbot-head">
        <img src="/static/img/riri.png" alt="Riri avatar" width="54" height="54">
        <div>
          <strong>Riri</strong>
          <span>Pastel art guide</span>
        </div>
      </div>
      <div class="chatbot-log" id="chatLog" role="log" aria-live="polite">
        <p><b>Riri:</b> Hi, welcome to Ru's Art Vault. I am Riri, your pastel art friend. What would you like to explore today?</p>
      </div>
      <form id="chatForm" aria-label="Chat with Riri">
        <label for="chatInput" class="sr-only">Ask Riri a question</label>
        <input id="chatInput" type="text" placeholder="Ask Riri about artworks..." autocomplete="off">
